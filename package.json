{
  "name": "vpn-client-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted VPN Client desktop client for VLESS / REALITY",
  "main": "apps/desktop/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config apps/web/vite.config.js",
    "dev:electron": "wait-on tcp:5173 && node scripts/start-electron.js",
    "build:core-link": "node scripts/build-core-link.js",
    "build:renderer": "vite build --config apps/web/vite.config.js",
    "release:check": "npm run build:core-link && npm run build:renderer",
    "release:dir": "npm run release:clean && npm run build:core-link && npm run build:renderer && electron-builder --dir",
    "release:win": "npm run release:clean && npm run build:core-link && npm run build:renderer && electron-builder --win portable",
    "build": "npm run release:clean && npm run build:core-link && npm run build:renderer && electron-builder",
    "release:win:installer": "npm run release:clean && npm run build:core-link && npm run build:renderer && electron-builder --win nsis",
    "release:clean": "node -e \"require('fs').rmSync('release', { recursive: true, force: true })\""
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.klouse.vpnclient.desktop",
    "productName": "VPN Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "apps/desktop/**/*",
      "dist/apps/web/**/*",
      "package.json",
      "configs/.env.example",
      "configs/.env.production.example"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "vpn-client-desktop-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "vpn-client-desktop-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "artifactName": "vpn-client-desktop-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "vpn-client-desktop-portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "vpn-client-desktop-setup-${version}-${arch}.${ext}",
      "oneClick": true
    }
  },
  "author": "bycor"
}
